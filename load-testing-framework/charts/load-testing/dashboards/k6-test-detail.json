{
  "annotations": { "list": [] },
  "description": "k6 Load Testing — Per-Test Detail with HTTP breakdown",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "Back to Overview", "url": "/d/k6-load-testing-overview", "type": "link" }
  ],
  "panels": [
    {
      "title": "HTTP Request Duration — Distribution",
      "description": "응답 시간 분포를 백분위수 밴드로 표시합니다.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p50 (median)" },
        { "expr": "histogram_quantile(0.75, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p75" },
        { "expr": "histogram_quantile(0.90, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "gradientMode": "scheme" }, "unit": "s" } }
    },
    {
      "title": "Response Time Trends",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "s" } }
    },
    {
      "title": "Throughput Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(k6_http_reqs_total[$__rate_interval])", "legendFormat": "Total req/s" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "unit": "reqps" } }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "k6_http_req_failed_rate", "legendFormat": "error rate — {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "fillOpacity": 30, "lineWidth": 2 }, "unit": "percentunit" } }
    },
    {
      "title": "Iteration Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(k6_iterations_total[$__rate_interval])", "legendFormat": "iterations/s — {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "itr/s" } }
    },
    {
      "title": "Data Transfer",
      "description": "k6가 송수신한 데이터량.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(k6_data_received_total[$__rate_interval])", "legendFormat": "Received" },
        { "expr": "rate(k6_data_sent_total[$__rate_interval])", "legendFormat": "Sent" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2 }, "unit": "Bps" } }
    },
    {
      "title": "VU Ramp Profile",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "k6_vus", "legendFormat": "Active VUs" },
        { "expr": "k6_vus_max", "legendFormat": "Max VUs" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "load-testing", "detail"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus-LoadTesting", "value": "Prometheus-LoadTesting" }
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, environment)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "test_type",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, test_type)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "scenario",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, scenario)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "k6 Load Testing — Test Detail",
  "uid": "k6-load-testing-detail"
}