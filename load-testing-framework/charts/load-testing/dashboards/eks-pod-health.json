{
  "annotations": { "list": [] },
  "description": "EKS Pod Health — errors (restarts, OOMKilled, not ready) and saturation (CPU/memory vs limits)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Pod Restart Count (Total)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$pod\"}) by (pod)", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "showPoints": "never", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }, "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "title": "Pod Restart Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$pod\"}[$__rate_interval])) by (pod) * 60", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "showPoints": "never", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }, "unit": "short" } }
    },
    {
      "title": "Pod Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "count(kube_pod_status_phase{namespace=~\"$namespace\", phase=~\"$phase\"} == 1) or vector(0)", "legendFormat": "Pods", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "OOMKilled Containers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(kube_pod_container_status_last_terminated_reason{namespace=~\"$namespace\", reason=\"OOMKilled\"}) or vector(0)", "legendFormat": "OOMKilled", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "title": "Pod CPU Usage vs Limits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\"}[$__rate_interval])) by (pod)", "legendFormat": "usage — {{pod}}" },
        { "expr": "sum(kube_pod_container_resource_limits{namespace=~\"$namespace\", pod=~\"$pod\", resource=\"cpu\"}) by (pod)", "legendFormat": "limit — {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "showPoints": "never", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }, "unit": "short" } }
    },
    {
      "title": "Pod Memory Usage vs Limits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\"}) by (pod)", "legendFormat": "usage — {{pod}}" },
        { "expr": "sum(kube_pod_container_resource_limits{namespace=~\"$namespace\", pod=~\"$pod\", resource=\"memory\"}) by (pod)", "legendFormat": "limit — {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "showPoints": "never", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }, "unit": "bytes" } }
    },
    {
      "title": "Container Not Ready",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "count(kube_pod_container_status_ready{namespace=~\"$namespace\", pod=~\"$pod\"} == 0) or vector(0)", "legendFormat": "Not Ready" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "drawStyle": "line", "showPoints": "never", "fillOpacity": 15, "lineWidth": 2, "spanNulls": true }, "unit": "short" } }
    },
    {
      "title": "Pod Restarts Table",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"$namespace\", pod=~\"$pod\"}) by (namespace, pod) > 0", "legendFormat": "{{namespace}}/{{pod}}", "instant": true, "format": "table" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Restart Count" }] }, { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }] },
      "transformations": [{ "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] } }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["eks", "pod", "health", "load-testing"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus-LoadTesting", "value": "Prometheus-LoadTesting" }
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "phase",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(kube_pod_status_phase{namespace=~\"$namespace\"}, phase)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "Running", "value": "Running" }
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "query_result(kube_pod_status_phase{namespace=~\"$namespace\", phase=~\"$phase\"} == 1)",
        "regex": ".*pod=\"([^\"]+)\".*",
        "refresh": 2,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "EKS Pod Health",
  "uid": "eks-pod-health"
}