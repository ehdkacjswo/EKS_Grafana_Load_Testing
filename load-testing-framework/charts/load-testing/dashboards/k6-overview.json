{
  "annotations": { "list": [] },
  "description": "k6 Load Testing Overview — request rate, latency, errors, VUs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Virtual Users (VUs)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "k6_vus", "legendFormat": "VUs — {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" } }
    },
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(k6_http_reqs_total[$__rate_interval])", "legendFormat": "req/s — {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "reqps" } }
    },
    {
      "title": "HTTP Request Duration — Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_seconds[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2 }, "unit": "s" } }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(k6_http_reqs_total{expected_response=\"false\"}[$__rate_interval])) / sum(rate(k6_http_reqs_total[$__rate_interval]))", "legendFormat": "error rate" }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "fillOpacity": 30, "lineWidth": 2 }, "unit": "percentunit" } }
    },
    {
      "title": "Test Status — Iterations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(increase(k6_iterations_total[1h]))", "legendFormat": "Total Iterations", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Test Status — Avg Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_avg(sum(rate(k6_http_req_duration_seconds[5m])))", "legendFormat": "Avg Duration", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Test Status — Error %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(k6_http_reqs_total{expected_response=\"false\"}[5m])) / sum(rate(k6_http_reqs_total[5m]))", "legendFormat": "Error %", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "Test Status — Peak VUs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "max(max_over_time(k6_vus[1h]))", "legendFormat": "Peak VUs", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Data Transferred",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(increase(k6_data_received_total[1h]))", "legendFormat": "Received", "instant": true },
        { "expr": "sum(increase(k6_data_sent_total[1h]))", "legendFormat": "Sent", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["k6", "load-testing", "overview"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus-LoadTesting", "value": "Prometheus-LoadTesting" }
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, environment)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "test_type",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(k6_http_reqs_total, test_type)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "k6 Load Testing — Overview",
  "uid": "k6-load-testing-overview"
}